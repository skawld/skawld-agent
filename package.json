{
  "name": "skawld",
  "version": "0.1.0",
  "description": "An open-source TypeScript agent harness for software engineering.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18",
    "bun": ">=1.1"
  },
  "main": "./dist/sdk.js",
  "types": "./dist/sdk.d.ts",
  "exports": {
    ".": {
      "import": "./dist/sdk.js",
      "types": "./dist/sdk.d.ts"
    },
    "./providers": {
      "import": "./dist/providers/index.js",
      "types": "./dist/providers/index.d.ts"
    },
    "./tools": {
      "import": "./dist/tools/index.js",
      "types": "./dist/tools/index.d.ts"
    },
    "./sessions": {
      "import": "./dist/sessions/index.js",
      "types": "./dist/sessions/index.d.ts"
    },
    "./permissions": {
      "import": "./dist/permissions/index.js",
      "types": "./dist/permissions/index.d.ts"
    }
  },
  "files": [
    "dist",
    "docs",
    "AGENTS.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "gen:version": "bun scripts/gen-version.ts",
    "build:js": "bun build src/sdk.ts src/providers/index.ts src/tools/index.ts src/sessions/index.ts src/permissions/index.ts --outdir dist --root src --target node --sourcemap=linked --external better-sqlite3 --external bun:sqlite",
    "build:types": "tsc --emitDeclarationOnly",
    "build": "bun run clean && bun run gen:version && bun run build:js && bun run build:types",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:dist": "bun run build && SKAWLD_DIST_TEST=1 bun test tests/sdk/dist-smoke.test.ts tests/sdk/nodenext-consumer.test.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run build && bun test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.0.0",
    "fast-glob": "^3.3.0",
    "ignore": "^7.0.0",
    "openai": "^5.0.0",
    "picomatch": "^4.0.0",
    "tree-kill": "^1.2.2",
    "yaml": "^2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/bun": "latest",
    "@types/picomatch": "^3.0.0",
    "typescript": "^5.4.0"
  }
}
